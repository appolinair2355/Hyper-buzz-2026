# ============================================================
# BACCARAT PRO ✨ — Variables d'environnement requises
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# Token du bot Telegram (obtenu via @BotFather)
BOT_TOKEN=

# Identifiants de l'application Telegram (https://my.telegram.org)
API_ID=
API_HASH=

# ID Telegram de l'administrateur du bot
ADMIN_ID=

# Session Telegram encodée en base64 (générée au premier démarrage)
TELEGRAM_SESSION=

# ── Canaux silencieux (un par compteur) ────────────────────
# Compteur 1 : B=5 | mapping ♣↔♦, ♠↔♥
C1_SILENT_CHANNEL_ID=

# Compteur 2 : B=8 | mapping ♥↔♣, ♠↔♦
C2_SILENT_CHANNEL_ID=

# Compteur 3 : B=5 | mapping ❤↔♣, ♠↔♦
C3_SILENT_CHANNEL_ID=

# ── Canal d'escalade (double canal après seuil de pertes) ──
# Reçoit la prédiction EN PLUS du canal silencieux quand :
#   C1 : 2 pertes consécutives | C2 : 1 perte | C3 : 2 pertes consécutives
DOUBLE_CANAL_CHANNEL_ID=

# ── Canal principal (prédictions directes) ─────────────────
PREDICTION_CHANNEL_ID=

# ── Paramètres optionnels ──────────────────────────────────
# Port du serveur health check (défaut: 10000)
PORT=10000

# Intervalle de polling API en secondes (défaut: 5)
API_POLL_INTERVAL=5
